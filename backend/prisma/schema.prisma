generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Report {
  id        String   @id @default(uuid())
  lat       Float
  lng       Float
  category  String
  severity  Int
  description String?
}

model AreaRisk {
  id   String @id @default(uuid())
  area String
  lat  Float
  lng  Float
  risk Int
}
